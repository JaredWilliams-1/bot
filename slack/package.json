{
  "name": "claudia-slack-bot",
  "version": "1.0.0",
  "description": "Claudia Slack integration: memory-aware AI assistant bot",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file=../.env server.js",
    "dev": "node --env-file=../.env --watch server.js",
    "start:memory": "node --env-file=../.env start-memory.js",
    "dev:all": "node --env-file=../.env start-memory.js & node --env-file=../.env --watch server.js; kill 0",
    "setup": "node setup.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@slack/bolt": "^4.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "googleapis": "^173.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
