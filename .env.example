# Claudia Environment Variables
#
# Copy this file to .env and fill in all required values.
# Lines starting with # are comments.
# Never commit .env to version control.

###############################################################################
# REQUIRED: Slack Bot credentials
# Get these from https://api.slack.com/apps after creating a Slack app.
###############################################################################

# Bot OAuth token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Signing secret (from App > Basic Information > Signing Secret)
SLACK_SIGNING_SECRET=your-signing-secret-here

# App-level token for Socket Mode (starts with xapp-)
# Only required when SLACK_SOCKET_MODE=true
SLACK_APP_TOKEN=

###############################################################################
# REQUIRED: Anthropic API key
# Get from https://console.anthropic.com/account/keys
###############################################################################

ANTHROPIC_API_KEY=sk-ant-your-key-here

###############################################################################
# REQUIRED: Memory API key
# This key authenticates requests from the Slack bot to the memory daemon.
# Generate with: openssl rand -base64 32
# The memory daemon will print a generated key at startup if this is unset.
###############################################################################

MEMORY_API_KEY=generate-a-random-key-here

###############################################################################
# Slack bot configuration (optional, defaults shown)
###############################################################################

# Model to use for Claude responses
CLAUDE_MODEL=claude-sonnet-4-6

# Port for the Slack bot's HTTP Events API server
# If using Socket Mode, this is the health check port.
SLACK_PORT=3851

# Set to "true" to use Socket Mode instead of HTTP Events API.
# Socket Mode does not require a public URL (good for local dev).
# HTTP Events API requires a public URL (use with a reverse proxy).
SLACK_SOCKET_MODE=false

# Max tokens in Claude responses (keep low for Slack chat)
MAX_TOKENS=1024

# How many past memories to inject as context for each message
MEMORY_RECALL_LIMIT=6

# Override the Claude system prompt (optional)
# SLACK_SYSTEM_PROMPT=You are Claudia, a helpful AI assistant...

###############################################################################
# Memory daemon configuration (optional, defaults shown)
###############################################################################

# Base URL for the claudia-memory HTTP API
# In Docker Compose, this is overridden to http://memory-daemon:3850 internally.
MEMORY_API_URL=http://localhost:3850

# Per-user database base directory (optional override)
# USER_DB_BASE_DIR=/home/user/.claudia/memory/users

###############################################################################
# Web GUI / Visualizer authentication (optional)
###############################################################################

# Secret key for JWT signing. Generate with: openssl rand -hex 32
# A random key is generated at startup if unset (sessions won't survive restarts).
AUTH_SECRET=generate-a-hex-secret-here

# Set to "true" to disable authentication entirely (local development)
AUTH_DISABLED=true

# Slack OAuth app credentials for SSO login to the visualizer
# (Optional: only needed if AUTH_DISABLED=false)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Port the visualizer listens on (exposed by the visualizer container)
VISUALIZER_PORT=3849

# Public URL of the visualizer (used for Slack OAuth redirect URI)
APP_URL=http://localhost:3849

# JWT session expiry in seconds (default: 86400 = 24 hours)
JWT_EXPIRY_SECONDS=86400

###############################################################################
# Docker / Deployment
###############################################################################

# Path on the host where Claudia data is stored (bind-mounted into containers)
# Defaults to ~/.claudia. Change if your home directory layout differs.
CLAUDIA_DATA_DIR=${HOME}/.claudia

###############################################################################
# Ollama (local embedding model)
# Used by the memory daemon to generate 384-dim embeddings.
# In Docker Compose, Ollama runs as a service on port 11434.
###############################################################################

OLLAMA_HOST=http://localhost:11434
